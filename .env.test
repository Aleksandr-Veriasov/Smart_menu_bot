# Local test profile for pytest
# Loaded automatically from tests/conftest.py when present.

APP_ENV=dev
DEBUG=false

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=test_smartmenubot
DB_SSLMODE=disable
DATABASE_TEST_URL=postgresql://postgres:postgres@localhost:5432/test_smartmenubot

# Minimal required settings for import-time config validation
DB_DUMP_DROPBOX_REFRESH_TOKEN=ci_dropbox_refresh_token
DB_DUMP_DROPBOX_APP_KEY=ci_dropbox_app_key
DB_DUMP_DROPBOX_APP_SECRET=ci_dropbox_app_secret
TELEGRAM_CHAT_ID=123456789
TELEGRAM_BOT_TOKEN=dummy_test_token
TELEGRAM_ADMIN_ID=987654321
TELEGRAM_USE_WEBHOOK=false
WEBHOOK_PREFIX=tg
WEBHOOK_SLUG=ci_slug
WEBHOOK_SECRET_TOKEN=ci_secret
DEEPSEEK_API_KEY=test
DEEPSEEK_BASE_URL=https://api.example.com
DEEPSEEK_MODEL=deepseek-test-model
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin
PASSWORD_PEPPER=test_pepper_string
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=testpassword
TG_API_ID=123456
TG_API_HASH=test_telethon_hash
